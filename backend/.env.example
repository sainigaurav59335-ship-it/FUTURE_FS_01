# Server Configuration
PORT=5000

# Optional MongoDB Database Connection URI (Prioritized NoSQL database)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/portfolio?retryWrites=true&w=majority

# Optional MySQL Database Connection Settings (Prioritized SQL database if MongoDB is omitted)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_DATABASE=portfolio_db

# Recipient Email for Contact Form Submissions
CONTACT_RECEIVER_EMAIL=your-personal-email@example.com

# Nodemailer SMTP Configuration (Gmail / Outlook / SendGrid / Custom SMTP)
# If left blank, Nodemailer generates an Ethereal sandbox test account dynamically
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-username@gmail.com
SMTP_PASS=your-smtp-app-password
